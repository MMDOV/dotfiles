#!/usr/bin/env bash

# Detect if we're running from the repo or from installed location
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
if [[ -f "$SCRIPT_DIR/../tmux/sessions/home.sh" ]]; then
  # Running from repo
  REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
else
  # Running from installed location (~/.local/bin)
  # Use XDG_CONFIG_HOME or fallback to finding the repo
  REPO_ROOT="${DOTFILES_ROOT:-$HOME/personal}"
fi

SESSIONS_DIR="$REPO_ROOT/tmux/sessions"

switch_to() {
  if [[ -z $TMUX ]]; then
    tmux attach-session -t $1
  else
    tmux switch-client -t $1
  fi
}

has_session() {
  tmux list-sessions | grep -q "^$1:"
}

hydrate() {
  if [ $2 == "$HOME" ]; then
    tmux send-keys -t $1 "source $SESSIONS_DIR/home.sh" c-M
  elif [ -f $2/.tmux-sessionizer ]; then
    tmux send-keys -t $1 "source $2/.tmux-sessionizer" c-M
  else
    tmux send-keys -t $1 "source $SESSIONS_DIR/personal.sh" c-M
  fi
}

if [[ $# -eq 1 ]]; then
  selected=$1
else
  dirs=(
    "$HOME"
    "$HOME/.config"
  )

  for d in "$HOME/dev"*/; do
    dirs+=("$d")
  done
  for d in "$HOME/clones"*/; do
    dirs+=("$d")
  done
  selected=$(find "${dirs[@]}" -mindepth 1 -maxdepth 1 -type d 2>/dev/null | fzf)
fi

if [[ -z $selected ]]; then
  exit 0
fi

selected_name=$(basename "$selected" | tr . _)
tmux_running=$(pgrep tmux)

if [[ -z $TMUX ]] && [[ -z $tmux_running ]]; then
  tmux new-session -s $selected_name -c $selected
  hydrate $selected_name $selected
  exit 0
fi

if ! has_session $selected_name; then
  tmux new-session -ds $selected_name -c $selected
  hydrate $selected_name $selected
fi

switch_to $selected_name
